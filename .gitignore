# ============================================================================
# Quantum AI Laboratory — .gitignore
# ============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.env
.venv
env/
venv/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Jupyter Notebook
.ipynb_checkpoints

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# mypy
.mypy_cache/
dmypy.json

# Matplotlib
*.png
*.jpg
*.jpeg
*.gif
*.svg
!docs/**/*.png
!docs/**/*.svg

# OS
.DS_Store
Thumbs.db

# Data files
*.csv
*.h5
*.hdf5
*.pkl
*.pickle
*.npy
*.npz

# Logs
*.log
